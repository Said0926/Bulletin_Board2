# Secrets — never commit these
.env
*.env
.env.*
# Allow example/template env files
!.env.example
!**/.env.example
!.env.local.example
!**/.env.local.example

# Python
__pycache__/
*.pyc
*.pyo
venv/
env/
.venv/

# Django
backend/db.sqlite3
backend/media/
backend/staticfiles/

# Frontend (also covered by frontend/.gitignore)
frontend/.next/
frontend/node_modules/
frontend/out/

# gstack security reports (local only)
.gstack/

# OS
.DS_Store
Thumbs.db

# Local tool artifacts
.playwright-mcp/
